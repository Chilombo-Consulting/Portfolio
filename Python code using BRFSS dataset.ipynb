   "outputs": [],
   "source": [
    "df = pd.read_csv(\"BRFSS_SC2022_WEIGHTED.csv\")[['heart','stroke','diabetes','covid','longcovid',\n",
    "    'race','education','income','employed','sex',\n",
    "    'food','transport','_llcpwt','age','renthom1']]\n",
    "df['sex'] = df['sex'] - 1\n",
    "df['renter'] = np.where(df['renthom1'] == 1, 0,\n",
    "                        np.where((df['renthom1'] == 2) | (df['renthom1'] == 3) | (df['renthom1'] == 7) | (df['renthom1'] == 9), 1, np.nan))\n",
    "df['prop'] = df[\"_llcpwt\"] / df[\"_llcpwt\"].sum()"
   ]
