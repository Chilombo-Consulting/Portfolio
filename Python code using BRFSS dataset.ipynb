   "source": [
    "import pandas as pd\n",
    "from pandas_profiling import ProfileReport\n",
    "import numpy as np\n",
    "import statsmodels.api as sm\n",
    "from sklearn.metrics import confusion_matrix\n",
    "\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a9c8a3e8-8d62-4e70-942c-1838ee1edc08",
   "metadata": {},
   "source": [
    "### Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 55,
   "id": "0c7fedf4-799a-4d85-b7d4-40a5c2fbd538",
   "metadata": {},
   "outputs": [],
   "source": [
    "def weighted_average(var):\n",
    "    val = df[var]\n",
    "    #wt = df[\"_llcpwt\"]\n",
    "    wt = df['prop']\n",
    "    return round((val * wt).sum() / wt.sum() *100,1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 89,
   "id": "c80379b9-afd3-4593-9c6c-efba4b5fb791",
   "metadata": {},
   "outputs": [],
   "source": [
    "def wgt_confusion_matrix(x_var):\n",
    "    true_labels = df[x_var]\n",
    "    predicted_labels = df['longcovid']\n",
    "    wt = df['prop']\n",
    "    print(confusion_matrix(true_labels, predicted_labels, sample_weight=wt))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 99,
   "id": "ef9def9e-d4ad-47f3-a868-a257145234c2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def odds_ratio(x_var, y_var):\n",
    "    X = sm.add_constant(np.array(df[x_var]))\n",
    "    y = np.array(df[y_var])\n",
    "\n",
    "    model = sm.Logit(y,X)\n",
    "    weights = df['prop']\n",
    "    result = model.fit(method='bfgs', weights=weights)\n",
    "\n",
    "    print(result.summary())\n",
    "\n",
    "    odds_ratio = round(np.exp(result.params[1]),3)\n",
    "    p_val = round(result.pvalues[1],3)\n",
    "    print(\"X: \", x_var, \"Y: \", y_var)\n",
    "    print(\"Odds Ratio: \", odds_ratio,\" p-value: \", p_val)    \n",
    "\n",
    "#BFGS (method='bfgs'):\n",
    "#BFGS is a quasi-Newton method that approximates the Hessian matrix (second derivative of the objective function) using successive gradient evaluations.\n",
    "#Pros: It generally converges quickly and is robust for many optimization problems.\n",
    "#Cons: It may not perform well with highly non-linear or poorly conditioned problems.\n",
    "#Newton's method (method='newton'):\n",
    "#Newton's method directly calculates the Hessian matrix and updates the parameter estimates based on the inverse of the Hessian.\n",
    "#Pros: Can converge quickly, especially for well-conditioned problems.\n",
    "#Cons: Requires computation and inversion of the Hessian matrix, which can be computationally expensive and may not converge for poorly conditioned problems.\n",
    "#BFGS with line search (method='basinhopping'):\n",
    "#Uses the BFGS optimization algorithm with a global optimization method called basin-hopping, which performs a random walk in parameter space to find the global minimum.\n",
    "#Pros: Can find the global minimum for non-convex objective functions.\n",
    "#Cons: May be computationally expensive and may not converge reliably.\n",
    "#Conjugate gradient descent (method='cg'):\n",
    "#Conjugate gradient descent is an iterative optimization algorithm that minimizes a function by conjugate directions.\n",
    "#Pros: Can be efficient for large-scale problems with many parameters.\n",
    "#Cons: May require tuning of parameters for optimal performance and may not converge for non-convex problems."
   ]
  },
